{
  "manifest_version": 2,
  "name": "Güvenlink",
  "version": "1.0.0",
  "description": "USOM destekli guvenlik kontrol eklentisi",
  "permissions": [
    "storage",
    "tabs",
    "alarms",
    "webNavigation",
    "<all_urls>"
  ],
  "background": {
    "scripts": [
      "shared.js",
      "idb.js",
      "background.js"
    ]
  },
  "browser_action": {
    "default_title": "Guvenlik",
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "content-script.js"
      ],
      "run_at": "document_start"
    }
  ],
  "web_accessible_resources": [
    "warning.html",
    "warning.js",
    "styles.css"
  ],
  "browser_specific_settings": {
    "gecko": {
      "id": "guvenlink@example.com"
    }
  }
}
